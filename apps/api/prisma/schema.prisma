generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccessLevelCode {
  N1
  N2
  N3
  N4
}

enum PermissionOverrideType {
  grant
  deny
}

enum UploadStatus {
  pendente
  processado
  erro
  substituido
  removido
}

enum DocumentTypeCode {
  espelho
  nota_fiscal
}

enum TicketStatus {
  aberto
  em_andamento
  aguardando
  aguardando_motorista
  resolvido
  cancelado
  concluido
}

enum InvoiceStatus {
  pendente
  aprovada
  rejeitada
}

enum DriverPdfReceivedStatus {
  pdf_aguardando_envio
  pdf_enviado_ao_motorista
  motorista_visualizou
  aguardando_envio_nota_fiscal
  nota_fiscal_recebida
  nota_fiscal_em_analise
  nota_fiscal_aprovada
  nota_fiscal_rejeitada
  em_atendimento
  chamado_aberto
  processo_concluido
}

enum PaymentFrequencyCode {
  semanal
  quinzenal
  mensal
}

enum PeriodStatus {
  disponivel
  aguardando_aprovacao
  aprovado
}

enum MotoristaStatusCode {
  ativo
  inativo
  bloqueado
}

enum TicketPriorityCode {
  baixa
  media
  alta
  critica
}

enum AtendimentoChannelCode {
  chat
  whatsapp
  telefone
  email
  presencial
}

model Nivel {
  id                  String              @id @default(uuid()) @db.Uuid
  codigo              AccessLevelCode     @unique
  nome                String              @db.VarChar(100)
  descricao           String?
  usuarios            Usuario[]
  permissoesPorNivel  PermissaoPorNivel[]

  @@map("niveis")
}

model Usuario {
  id                           String                  @id @default(uuid()) @db.Uuid
  nome                         String                  @db.VarChar(150)
  email                        String                  @unique @db.VarChar(150)
  fotoPerfil                   String?                 @map("foto_perfil") @db.VarChar(255)
  senhaHash                    String                  @map("senha_hash")
  nivelId                      String                  @map("nivel_id") @db.Uuid
  ativo                        Boolean                 @default(true)
  bloqueado                    Boolean                 @default(false)
  primeiroAcesso               Boolean                 @default(true) @map("primeiro_acesso")
  ultimoLoginEm                DateTime?               @map("ultimo_login_em")
  criadoEm                     DateTime                @default(now()) @map("criado_em")
  atualizadoEm                 DateTime                @updatedAt @map("atualizado_em")
  nivel                        Nivel                   @relation(fields: [nivelId], references: [id])
  permissoesPorUsuario         PermissaoPorUsuario[]   @relation("PermissaoDestinoUsuario")
  permissoesConcedidas         PermissaoPorUsuario[]   @relation("PermissaoConcedidaPor")
  uploads                      UploadPdf[]
  driverPdfsRecebidosCriados   DriverPdfReceived[]     @relation("DriverPdfReceivedCriadoPor")
  driverPdfsRecebidosAprovados DriverPdfReceived[]     @relation("DriverPdfReceivedAprovadoPor")
  driverPdfsRecebidosRejeitados DriverPdfReceived[]    @relation("DriverPdfReceivedRejeitadoPor")
  chamadosSolicitados          Chamado[]               @relation("ChamadoSolicitante")
  chamadosResponsaveis         Chamado[]               @relation("ChamadoResponsavel")
  atendimentosRealizados       Atendimento[]
  notasInternas                NotaAtendimento[]
  historicosChamado            HistoricoChamado[]
  logs                         LogAuditoria[]
  logsAtendimento              LogAtendimento[]
  sessoes                      Sessao[]
  periodosCriados              PeriodoPagamento[]

  @@index([nivelId])
  @@map("usuarios")
}

model BasePagamento {
  id             String                    @id @default(uuid()) @db.Uuid
  nome           String                    @unique @db.VarChar(150)
  tipoPadrao     PaymentFrequencyCode       @map("tipo_padrao")
  ativo          Boolean                   @default(true)
  uploads        UploadPdf[]
  periodosBases  PeriodoPagamentoBase[]
  pdfsRecebidos  DriverPdfReceived[]

  @@map("bases_pagamento")
}

model PeriodoPagamento {
  id             String                    @id @default(uuid()) @db.Uuid
  nome           String                    @db.VarChar(180)
  dataInicio     DateTime                  @map("data_inicio")
  dataFim        DateTime                  @map("data_fim")
  tipo           PaymentFrequencyCode
  status         PeriodStatus              @default(disponivel)
  criadoPorId    String                    @map("criado_por_id") @db.Uuid
  criadoEm       DateTime                  @default(now()) @map("criado_em")
  atualizadoEm   DateTime                  @updatedAt @map("atualizado_em")
  criadoPor      Usuario                   @relation(fields: [criadoPorId], references: [id])
  bases          PeriodoPagamentoBase[]
  uploads        UploadPdf[]
  pdfsRecebidos  DriverPdfReceived[]

  @@index([criadoPorId])
  @@map("periodos_pagamento")
}

model PeriodoPagamentoBase {
  id              String            @id @default(uuid()) @db.Uuid
  periodoId       String            @map("periodo_id") @db.Uuid
  basePagamentoId String            @map("base_pagamento_id") @db.Uuid
  periodo         PeriodoPagamento  @relation(fields: [periodoId], references: [id])
  basePagamento   BasePagamento     @relation(fields: [basePagamentoId], references: [id])

  @@unique([periodoId, basePagamentoId])
  @@index([basePagamentoId])
  @@map("periodos_pagamento_bases")
}

model Modulo {
  id            String       @id @default(uuid()) @db.Uuid
  codigo        String       @unique @db.VarChar(50)
  nome          String       @db.VarChar(100)
  descricao     String?
  ativo         Boolean      @default(true)
  permissoes    Permissao[]

  @@map("modulos")
}

model Permissao {
  id                    String                 @id @default(uuid()) @db.Uuid
  codigo                String                 @unique @db.VarChar(80)
  nome                  String                 @db.VarChar(120)
  moduloId              String                 @map("modulo_id") @db.Uuid
  modulo                Modulo                 @relation(fields: [moduloId], references: [id])
  permissoesPorNivel    PermissaoPorNivel[]
  permissoesPorUsuario  PermissaoPorUsuario[]

  @@index([moduloId])
  @@map("permissoes")
}

model PermissaoPorNivel {
  id           String      @id @default(uuid()) @db.Uuid
  nivelId      String      @map("nivel_id") @db.Uuid
  permissaoId  String      @map("permissao_id") @db.Uuid
  nivel        Nivel       @relation(fields: [nivelId], references: [id])
  permissao    Permissao   @relation(fields: [permissaoId], references: [id])

  @@unique([nivelId, permissaoId])
  @@index([permissaoId])
  @@map("permissoes_por_nivel")
}

model PermissaoPorUsuario {
  id            String                  @id @default(uuid()) @db.Uuid
  usuarioId     String                  @map("usuario_id") @db.Uuid
  permissaoId   String                  @map("permissao_id") @db.Uuid
  tipo          PermissionOverrideType
  concedidoPor  String                  @map("concedido_por") @db.Uuid
  criadoEm      DateTime                @default(now()) @map("criado_em")
  usuario       Usuario                 @relation("PermissaoDestinoUsuario", fields: [usuarioId], references: [id])
  permissao     Permissao               @relation(fields: [permissaoId], references: [id])
  concedente    Usuario                 @relation("PermissaoConcedidaPor", fields: [concedidoPor], references: [id])

  @@unique([usuarioId, permissaoId])
  @@index([permissaoId])
  @@index([concedidoPor])
  @@map("permissoes_por_usuario")
}

model UploadPdf {
  id                 String        @id @default(uuid()) @db.Uuid
  nomeArquivo        String        @map("nome_arquivo") @db.VarChar(255)
  nomeOriginal       String        @map("nome_original") @db.VarChar(255)
  caminhoArquivo     String        @map("caminho_arquivo")
  documentType       DocumentTypeCode? @map("document_type")
  content            Bytes?        @map("content")
  versao             Int           @default(1)
  status             UploadStatus
  usuarioId          String        @map("usuario_id") @db.Uuid
  motoristaId        String?       @map("motorista_id") @db.Uuid
  periodoPagamentoId String?       @map("periodo_pagamento_id") @db.Uuid
  basePagamentoId    String?       @map("base_pagamento_id") @db.Uuid
  substituiUploadId  String?       @map("substitui_upload_id") @db.Uuid
  criadoEm           DateTime      @default(now()) @map("criado_em")
  usuario            Usuario       @relation(fields: [usuarioId], references: [id])
  motorista          Motorista?    @relation(fields: [motoristaId], references: [id])
  periodoPagamento   PeriodoPagamento? @relation(fields: [periodoPagamentoId], references: [id])
  basePagamento      BasePagamento? @relation(fields: [basePagamentoId], references: [id])
  substituiUpload    UploadPdf?    @relation("UploadVersao", fields: [substituiUploadId], references: [id])
  novasVersoes       UploadPdf[]   @relation("UploadVersao")

  @@index([usuarioId])
  @@index([motoristaId])
  @@index([periodoPagamentoId])
  @@index([basePagamentoId])
  @@index([substituiUploadId])
  @@map("uploads_pdf")
}

model Motorista {
  id                  String                    @id @default(uuid()) @db.Uuid
  nome                String                    @db.VarChar(150)
  cpf                 String                    @unique @db.VarChar(20)
  rg                  String?                   @db.VarChar(30)
  dataNascimento      DateTime?                 @map("data_nascimento")
  telefone            String?                   @db.VarChar(30)
  whatsapp            String?                   @db.VarChar(30)
  email               String?                   @db.VarChar(150)
  endereco            String?                   @db.VarChar(255)
  cidade              String?                   @db.VarChar(120)
  estado              String?                   @db.VarChar(80)
  cep                 String?                   @db.VarChar(20)
  statusCadastro      MotoristaStatusCode       @default(ativo) @map("status_cadastro")
  empresaVinculada    String?                   @map("empresa_vinculada") @db.VarChar(150)
  observacoesGerais   String?                   @map("observacoes_gerais")
  criadoEm            DateTime                  @default(now()) @map("criado_em")
  atualizadoEm        DateTime                  @updatedAt @map("atualizado_em")
  uploads             UploadPdf[]
  pdfsRecebidos       DriverPdfReceived[]
  atendimentos        Atendimento[]
  chamados            Chamado[]
  notas               NotaAtendimento[]
  classificacoes      MotoristaClassificacao[]
  logs                LogAtendimento[]

  @@index([nome])
  @@index([cpf])
  @@map("motoristas")
}

model ClassificacaoMotorista {
  id            String                    @id @default(uuid()) @db.Uuid
  nome          String                    @unique @db.VarChar(120)
  descricao     String?
  ativa         Boolean                   @default(true)
  criadaEm      DateTime                  @default(now()) @map("criada_em")
  atualizadaEm  DateTime                  @updatedAt @map("atualizada_em")
  motoristas    MotoristaClassificacao[]

  @@map("classificacoes_motorista")
}

model MotoristaClassificacao {
  id                 String                 @id @default(uuid()) @db.Uuid
  motoristaId        String                 @map("motorista_id") @db.Uuid
  classificacaoId    String                 @map("classificacao_id") @db.Uuid
  criadoEm           DateTime               @default(now()) @map("criado_em")
  motorista          Motorista              @relation(fields: [motoristaId], references: [id])
  classificacao      ClassificacaoMotorista  @relation(fields: [classificacaoId], references: [id])

  @@unique([motoristaId, classificacaoId])
  @@index([classificacaoId])
  @@map("motorista_classificacoes")
}

model Atendimento {
  id                String         @id @default(uuid()) @db.Uuid
  motoristaId       String         @map("motorista_id") @db.Uuid
  atendenteId       String         @map("atendente_id") @db.Uuid
  canal             AtendimentoChannelCode
  resumo            String         @db.VarChar(255)
  observacoes       String?
  tempoMinutos      Int?           @map("tempo_minutos")
  dataHora          DateTime       @default(now()) @map("data_hora")
  motorista         Motorista      @relation(fields: [motoristaId], references: [id])
  atendente         Usuario        @relation(fields: [atendenteId], references: [id])

  @@index([motoristaId])
  @@index([atendenteId])
  @@map("atendimentos")
}

model Chamado {
  id             String        @id @default(uuid()) @db.Uuid
  motoristaId    String?       @map("motorista_id") @db.Uuid
  titulo         String        @db.VarChar(180)
  assunto        String?       @db.VarChar(180)
  categoria      String?       @db.VarChar(120)
  prioridade     TicketPriorityCode @default(media)
  descricao      String
  status         TicketStatus  @default(aberto)
  solicitanteId  String        @map("solicitante_id") @db.Uuid
  responsavelId  String?       @map("responsavel_id") @db.Uuid
  abertoEm       DateTime      @default(now()) @map("aberto_em")
  atualizadoEm   DateTime      @updatedAt @map("atualizado_em")
  encerradoEm    DateTime?     @map("encerrado_em")
  motivoConclusao String?      @map("motivo_conclusao")
  solucaoAplicada String?      @map("solucao_aplicada")
  observacoesFinais String?    @map("observacoes_finais")
  tempoTotalMinutos Int?       @map("tempo_total_minutos")
  criadoEm       DateTime      @default(now()) @map("criado_em")
  motorista      Motorista?    @relation(fields: [motoristaId], references: [id])
  solicitante    Usuario       @relation("ChamadoSolicitante", fields: [solicitanteId], references: [id])
  responsavel    Usuario?      @relation("ChamadoResponsavel", fields: [responsavelId], references: [id])
  historicos     HistoricoChamado[]
  anexos         AnexoChamado[]

  @@index([motoristaId])
  @@index([solicitanteId])
  @@index([responsavelId])
  @@map("chamados")
}

model HistoricoChamado {
  id             String      @id @default(uuid()) @db.Uuid
  chamadoId      String      @map("chamado_id") @db.Uuid
  usuarioId      String      @map("usuario_id") @db.Uuid
  descricao      String
  criadoEm       DateTime    @default(now()) @map("criado_em")
  chamado        Chamado     @relation(fields: [chamadoId], references: [id])
  usuario        Usuario     @relation(fields: [usuarioId], references: [id])
  anexos         AnexoChamado[]

  @@index([chamadoId])
  @@index([usuarioId])
  @@map("historico_chamados")
}

model AnexoChamado {
  id                 String            @id @default(uuid()) @db.Uuid
  chamadoId          String            @map("chamado_id") @db.Uuid
  historicoChamadoId  String?           @map("historico_chamado_id") @db.Uuid
  nomeArquivo        String            @map("nome_arquivo") @db.VarChar(255)
  nomeOriginal       String            @map("nome_original") @db.VarChar(255)
  caminhoArquivo     String            @map("caminho_arquivo")
  criadoEm           DateTime          @default(now()) @map("criado_em")
  chamado            Chamado           @relation(fields: [chamadoId], references: [id])
  historicoChamado   HistoricoChamado? @relation(fields: [historicoChamadoId], references: [id])

  @@index([chamadoId])
  @@index([historicoChamadoId])
  @@map("anexos_chamados")
}

model NotaAtendimento {
  id            String      @id @default(uuid()) @db.Uuid
  motoristaId   String      @map("motorista_id") @db.Uuid
  usuarioId     String      @map("usuario_id") @db.Uuid
  conteudo      String
  criadoEm      DateTime    @default(now()) @map("criado_em")
  atualizadoEm  DateTime    @updatedAt @map("atualizado_em")
  motorista     Motorista   @relation(fields: [motoristaId], references: [id])
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])

  @@index([motoristaId])
  @@index([usuarioId])
  @@map("notas_atendimento")
}

model LogAtendimento {
  id           String     @id @default(uuid()) @db.Uuid
  motoristaId  String?    @map("motorista_id") @db.Uuid
  chamadoId    String?    @map("chamado_id") @db.Uuid
  usuarioId    String?    @map("usuario_id") @db.Uuid
  acao         String     @db.VarChar(100)
  entidade     String     @db.VarChar(100)
  entidadeId   String?    @map("entidade_id") @db.Uuid
  detalhes     Json?
  criadoEm     DateTime   @default(now()) @map("criado_em")
  motorista    Motorista? @relation(fields: [motoristaId], references: [id])
  usuario      Usuario?    @relation(fields: [usuarioId], references: [id])

  @@index([motoristaId])
  @@index([chamadoId])
  @@index([usuarioId])
  @@map("logs_atendimento")
}

model NotaFiscal {
  id         String         @id @default(uuid()) @db.Uuid
  numero     String         @db.VarChar(60)
  fornecedor String         @db.VarChar(150)
  valor      Decimal        @db.Decimal(14, 2)
  status     InvoiceStatus
  criadoEm   DateTime       @default(now()) @map("criado_em")

  @@map("notas_fiscais")
}

model DriverPdfReceived {
  id                   String                  @id @default(uuid()) @db.Uuid
  motoristaId          String?                 @map("motorista_id") @db.Uuid
  periodoPagamentoId   String?                 @map("periodo_pagamento_id") @db.Uuid
  basePagamentoId      String?                 @map("base_pagamento_id") @db.Uuid
  nomeArquivo          String?                 @map("nome_arquivo") @db.VarChar(255)
  caminhoArquivo       String?                 @map("caminho_arquivo")
  documentType         DocumentTypeCode?       @map("document_type")
  tipoArquivo          String?                 @map("tipo_arquivo") @db.VarChar(80)
  uploadEm             DateTime                @default(now()) @map("upload_em")
  usuarioId            String?                 @map("usuario_id") @db.Uuid
  status               DriverPdfReceivedStatus @default(pdf_aguardando_envio)
  observacoes          String?
  visualizadoEm        DateTime?               @map("visualizado_em")
  enviadoAoMotoristaEm DateTime?               @map("enviado_ao_motorista_em")
  aprovadoEm           DateTime?               @map("aprovado_em")
  aprovadoPorId        String?                 @map("aprovado_por_id") @db.Uuid
  rejeitadoEm          DateTime?               @map("rejeitado_em")
  rejeitadoPorId       String?                 @map("rejeitado_por_id") @db.Uuid
  motivoRejeicao       String?                 @map("motivo_rejeicao")
  atualizadoEm         DateTime                @updatedAt @map("atualizado_em")
  content              Bytes?                  @map("content")
  fullName             String?                 @map("full_name")
  cpf                  String?                 @map("cpf")
  cpfDigits            String?                 @map("cpf_digits")
  email                String?                 @map("email")
  role                 String?                 @map("role")
  motoristaNome        String?                 @map("motorista_nome")
  motoristaCpf         String?                 @map("motorista_cpf")
  uploadPdfId          String?                 @map("upload_pdf_id") @db.Uuid
  nomeOriginalLegacy   String?                 @map("nome_original")
  sentAt               DateTime?               @map("sent_at") @db.Timestamptz(6)
  openedAt             DateTime?               @map("opened_at") @db.Timestamptz(6)
  createdAt            DateTime?               @map("created_at") @db.Timestamptz(6)
  updatedAtLegacy      DateTime?               @map("updated_at") @db.Timestamptz(6)
  motorista            Motorista?              @relation(fields: [motoristaId], references: [id])
  periodoPagamento     PeriodoPagamento?       @relation(fields: [periodoPagamentoId], references: [id])
  basePagamento        BasePagamento?          @relation(fields: [basePagamentoId], references: [id])
  usuario              Usuario?                @relation("DriverPdfReceivedCriadoPor", fields: [usuarioId], references: [id])
  aprovador            Usuario?                @relation("DriverPdfReceivedAprovadoPor", fields: [aprovadoPorId], references: [id])
  rejeitador           Usuario?                @relation("DriverPdfReceivedRejeitadoPor", fields: [rejeitadoPorId], references: [id])

  @@index([motoristaId])
  @@index([periodoPagamentoId])
  @@index([basePagamentoId])
  @@index([usuarioId])
  @@index([aprovadoPorId])
  @@index([rejeitadoPorId])
  @@index([status])
  @@map("driver_pdf_received")
}

model LogAuditoria {
  id         String    @id @default(uuid()) @db.Uuid
  usuarioId  String?   @map("usuario_id") @db.Uuid
  acao       String    @db.VarChar(80)
  entidade   String    @db.VarChar(80)
  entidadeId String?   @map("entidade_id") @db.Uuid
  detalhes   Json?
  ipOrigem   String?   @map("ip_origem") @db.VarChar(64)
  userAgent  String?   @map("user_agent")
  criadoEm   DateTime  @default(now()) @map("criado_em")
  usuario    Usuario?  @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@map("logs_auditoria")
}

model Sessao {
  id          String    @id @default(uuid()) @db.Uuid
  usuarioId   String    @map("usuario_id") @db.Uuid
  tokenHash   String    @map("token_hash")
  expiraEm    DateTime  @map("expira_em")
  revogadaEm  DateTime? @map("revogada_em")
  criadoEm    DateTime  @default(now()) @map("criado_em")
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@map("sessoes")
}
